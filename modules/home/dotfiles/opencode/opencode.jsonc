{
  "$schema": "https://opencode.ai/config.json",
  "model": "opencode-go/minimax-m2.7",
  "small_model": "opencode-go/deepseek-v4-flash",
  "instructions": [
    "/home/gabrln/Documents/obsidian/C04 Agent/Agent Workflow.md",
    "/home/gabrln/Documents/obsidian/C04 Agent/Reference/Config Reference.md"
  ],
  "skills": {
    "paths": ["/home/gabrln/Documents/obsidian/C04 Agent/Skills"]
  },
  "agent": {
    "build": {
      "model": "opencode-go/minimax-m2.7"
    },
    "plan": {
      "model": "opencode-go/deepseek-v4-flash"
    },
    "explore": {
      "model": "opencode-go/deepseek-v4-flash"
    },
    "general": {
      "model": "opencode-go/deepseek-v4-flash"
    }
  },
  "command": {
    "check": {
      "description": "Roda nix flake check no config repo",
      "template": "Execute `nix flake check` em ~/.config/nixos e reporte o resultado completo."
    },
    "rebuild": {
      "description": "Rebuild + switch do NixOS",
      "template": "Execute `cd ~/.config/nixos && sudo nixos-rebuild switch --flake .#gabrln` e reporte o resultado."
    }
  },
  "formatter": {
    "nixfmt": {
      "command": ["nixfmt"],
      "extensions": [".nix"]
    }
  },
  "mcp": {
    "nixos": {
      "type": "local",
      "command": ["mcp-nixos"],
      "enabled": true
    }
  },
  "permission": {
    "bash": {
      "git *": "allow",
      "nixos-rebuild *": "allow",
      "nix flake *": "allow",
      "mkdir *": "allow",
      "*": "ask"
    }
  },
  "compaction": {
    "auto": true,
    "tail_turns": 25
  },
  "tool_output": {
    "max_lines": 500,
    "max_bytes": 102400
  }
}
