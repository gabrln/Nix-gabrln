{
  "$schema": "https://opencode.ai/config.json",
  "model": "opencode-go/minimax-m2.7",
  "small_model": "opencode-go/deepseek-v4-flash",
  "instructions": [
    "/home/gabrln/Documents/obsidian/C04 Agent/Agent Workflow.md",
    "/home/gabrln/Documents/obsidian/C04 Agent/Reference/Config Reference.md"
  ],
  "skills": {
    "paths": ["/home/gabrln/Documents/obsidian/C04 Agent/Skills"]
  },
  "agent": {
    "build": {
      "model": "opencode-go/minimax-m2.7",
      "permission": {
        "edit": "deny",
        "write": "deny",
        "bash": {
          "nix flake *": "allow",
          "*": "deny"
        },
        "task": {
          "spec": "allow",
          "design": "allow",
          "design-review": "allow",
          "apply": "allow",
          "verify": "allow",
          "vault-docs": "allow",
          "git-specialist": "allow",
          "*": "deny"
        }
      }
    },
    "plan": {
      "model": "opencode-go/deepseek-v4-flash"
    },
    "explore": {
      "model": "opencode-go/deepseek-v4-flash"
    },
    "general": {
      "model": "opencode-go/deepseek-v4-flash"
    }
  },
  "command": {
    "plan": {
      "description": "Inicia spec + design para uma request (Tier 3)",
      "template": "@spec Analisa e produz spec técnica para: $ARGUMENTS. Após spec completa, delegar para @design."
    },
    "rebuild": {
      "description": "Rebuild + switch do NixOS",
      "template": "Execute `cd ~/.config/nixos && sudo nixos-rebuild switch --flake .#gabrln` e reporte o resultado."
    },
    "docs": {
      "description": "Atualiza documentação do vault",
      "template": "@vault-docs Verifica e atualiza documentação no vault para: $ARGUMENTS"
    },
    "check": {
      "description": "Roda nix flake check no config repo",
      "template": "Execute `nix flake check` em ~/.config/nixos e reporte o resultado completo."
    }
  },
  "formatter": {
    "nixfmt": {
      "command": ["nixfmt"],
      "extensions": [".nix"]
    }
  },
  "mcp": {
    "nixos": {
      "type": "local",
      "command": ["mcp-nixos"],
      "enabled": true
    }
  },
  "permission": {
    "bash": {
      "git *": "allow",
      "nixos-rebuild *": "allow",
      "nix flake *": "allow",
      "mkdir *": "allow",
      "*": "ask"
    }
  },
  "compaction": {
    "auto": true,
    "tail_turns": 50
  },
  "tool_output": {
    "max_lines": 500,
    "max_bytes": 102400
  }
}
